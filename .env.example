# ── Cloudflare Tunnel ──────────────────────────────────────
CF_TUNNEL_TOKEN=              # Single tunnel token from CF Zero Trust dashboard
# Public hostnames (configured in CF dashboard, stored here for reference/scripts)
MAESTRO_PUBLIC_URL=wss://maestro.yourdomain.com
WEB_PUBLIC_URL=https://app.yourdomain.com

# ── Maestro ────────────────────────────────────────────────
NEXUS_MAESTRO_HOST=0.0.0.0
NEXUS_MAESTRO_PORT=9200
NEXUS_MAESTRO_DB=/data/maestro.db

# ── Core ───────────────────────────────────────────────────
NEXUS_CORE_HOST=0.0.0.0
NEXUS_CORE_PORT=9100
NEXUS_CORE_NAME=NexusCore
NEXUS_CORE_ID=core-default
NEXUS_MAESTRO_URL=ws://maestro:9200     # Core→Maestro connection (use ws://maestro:9200 for Docker, or omit to run Core standalone)
NEXUS_MAESTRO_TOKEN=                     # Access token from Maestro UI
NEXUS_CORE_EXTERNAL_URL=             # Public URL for OAuth callback (tunnel URL, e.g. https://core.example.com)
ANTHROPIC_API_KEY=
GITHUB_TOKEN=                        # GitHub PAT for cloning private repos

# ── Container Host Mounts (optional) ─────────────────────
# Format: Label1=/container/path,Label2=/container/path
# Example: mount ~/projects into container, then reference it here
# docker-compose volume: ~/projects:/host/projects
NEXUS_HOST_MOUNTS=                   # e.g. Projects=/host/projects,Home=/host/home

# ── Web Client (build-time) ───────────────────────────────
VITE_DEFAULT_MAESTRO_URL=wss://maestro.yourdomain.com
