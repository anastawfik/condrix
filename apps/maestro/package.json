{
  "name": "@nexus-core/maestro",
  "version": "0.1.0",
  "private": true,
  "description": "NexusCore orchestration layer — cross-core coordination, messaging bridge, and proactive notifications",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "nexus-maestro": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@nexus-core/protocol": "*",
    "ws": "^8.18.0",
    "better-sqlite3": "^11.0.0",
    "grammy": "^1.30.0",
    "@whiskeysockets/baileys": "^6.7.0",
    "uuid": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/uuid": "^10.0.0",
    "vitest": "^3.0.0"
  }
}
