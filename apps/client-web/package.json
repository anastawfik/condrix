{
  "name": "@nexus-core/client-web",
  "version": "0.1.0",
  "private": true,
  "description": "NexusCore web client — browser-based IDE experience sharing components with the desktop client",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
