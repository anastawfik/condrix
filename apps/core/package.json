{
  "name": "@nexus-core/core",
  "version": "0.1.0",
  "private": true,
  "description": "NexusCore agent runtime daemon — manages projects, workspaces, agents, terminals, and file operations",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "nexus-core": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "@anthropic-ai/sdk": "^0.80.0",
    "@nexus-core/protocol": "*",
    "better-sqlite3": "^11.0.0",
    "chokidar": "^4.0.0",
    "node-pty": "^1.0.0",
    "simple-git": "^3.27.0",
    "uuid": "^11.0.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "vitest": "^3.0.0"
  }
}
