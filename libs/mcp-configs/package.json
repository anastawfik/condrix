{
  "name": "@nexus-core/mcp-configs",
  "version": "0.1.0",
  "private": true,
  "description": "Pre-configured MCP (Model Context Protocol) server definitions for NexusCore",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@nexus-core/protocol": "*"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  }
}
