{
  "name": "@condrix/client-shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared React components, hooks, and utilities for Condrix clients",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@condrix/protocol": "*",
    "react": "^19.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
}
